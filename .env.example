# ════════════════════════════════════════════════════════════════════════════
#  FORJA backend — .env.example
#  Copiază acest fișier în `.env` și completează valorile.
# ════════════════════════════════════════════════════════════════════════════

# ── DATABASE (PostgreSQL) ───────────────────────────────────────────────────
# Local:
DATABASE_URL="postgresql://postgres:password@localhost:5432/forja?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/forja?schema=public"

# Neon (copiază din dashboard):
# DATABASE_URL="postgres://neondb_owner:xxxx@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgres://neondb_owner:xxxx@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ── SERVER ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"

# ── FRONTEND (pentru CORS) ──────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
# Origini CORS suplimentare (comma-separated, suportă wildcards pentru Vercel previews):
# FRONTEND_URL_EXTRA="https://*.vercel.app,https://forja.app"

# ── ADMIN REAL (creat automat la boot) ──────────────────────────────────────
ADMIN_EMAIL="admin@forja.ro"
ADMIN_PASSWORD="Admin1234"
ADMIN_NAME="FORJA Admin"

# Cheie pentru crearea admin-ului via POST /auth/register.
# Lasă gol dacă nu folosești bootstrap manual.
ADMIN_BOOTSTRAP_KEY=""
